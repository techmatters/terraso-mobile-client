#!/bin/bash

# Usage: rebuild_all [--run-only] <ios|android>

RUN_ONLY=false
if [[ "$1" == "--run-only" ]]; then
    RUN_ONLY=true
    shift
fi

PLATFORM="$1"

# Validate argument
if [[ "$PLATFORM" != "ios" && "$PLATFORM" != "android" ]]; then
    echo "Usage: rebuild_all [--run-only] <ios|android>"
    exit 1
fi

# Ensure we're in dev-client directory
if [[ "$PWD" == */dev-client ]]; then
    :
elif [[ -d "dev-client" ]]; then
    cd dev-client
else
    GIT_ROOT=$(git rev-parse --show-toplevel 2>/dev/null)
    if [[ -n "$GIT_ROOT" ]] && [[ -d "$GIT_ROOT/dev-client" ]]; then
        cd "$GIT_ROOT/dev-client"
    else
        echo "Error: Cannot find dev-client directory"
        exit 1
    fi
fi

if [[ "$RUN_ONLY" == false ]]; then
    echo "Building from $PWD for: $PLATFORM"

    rm -rf node_modules ios android

    # Clear Gradle build cache (can cause stale artifact issues)
    if [[ "$PLATFORM" == "android" ]]; then
        echo "Clearing Gradle build cache..."
        rm -rf ~/.gradle/caches/build-cache-1
    fi

    npm install
    npm run prepare
    npm run prebuild
else
    echo "Running from $PWD for: $PLATFORM (skipping rebuild)"
fi

# Wrap commands in a pseudo-TTY so the log streamer doesn't split long lines when piped
PTY="script -q /dev/null"

# Patterns to filter from iOS log output (one per line, grep -E syntax)
IOS_LOG_NOISE=(
    "CoreHaptics"
    "CHHapticPattern"
    "_UIKBFeedbackGenerator"
    "\\[MapboxCommon\\]"
    "Could not find view with tag"
)

# Join patterns with | for grep -Ev
IOS_LOG_FILTER=$(IFS='|'; echo "${IOS_LOG_NOISE[*]}")

if [[ "$PLATFORM" == "ios" ]]; then
    if [[ -n "$IOS_DEVICE_ID" ]]; then
        $PTY npm run ios -- --device "$IOS_DEVICE_ID" 2>&1 | grep -Ev "$IOS_LOG_FILTER"
    else
        $PTY npm run ios 2>&1 | grep -Ev "$IOS_LOG_FILTER"
    fi
else
    npm run android
fi
